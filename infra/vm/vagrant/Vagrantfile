Vagrant.configure("2") do |config|
  config.ssh.insert_key = false
  (1..8).each do |i|
    config.vm.define "wacloud-node-#{i}" do |node|
      # Base Image
      node.vm.box = "ubuntu/jammy64"
      node.vm.hostname = "wacloud-node-#{i}"
      config.ssh.insert_key = false
      # Networking
      node.vm.network "private_network", ip: "192.168.56.#{10 + i}"

      # PRIMARY DISK (OS) - Using the stable 2.4+ Disk API
      # Promoted from experimental: No more shrinking issues, handles resizing correctly.
      node.vm.disk :disk, size: "40GB", primary: true

      # SECONDARY DISK (Ceph OSD) - Only for nodes 6, 7, and 8
      if i >= 6
        node.vm.disk :disk, size: "20GB", name: "osd_storage_#{i}"
      end

      # PROVIDER CONFIGURATION
      node.vm.provider "virtualbox" do |vb|
        vb.name = "wacloud-node-#{i}"
        vb.cpus = 8
        # Memory allocation: 16GB for nodes 1-5, 8GB for nodes 6-8
        vb.memory = i <= 5 ? 16384 : 8192

        # NESTED VIRTUALIZATION & HARDWARE ACCELERATION
        # Required for KubeVirt and high-performance Ceph
        vb.customize ["modifyvm", :id, "--ioapic", "on"]
        vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
        vb.customize ["modifyvm", :id, "--nested-paging", "on"]
        vb.customize ["modifyvm", :id, "--hwvirtex", "on"]
        
        # Performance tuning for high CPU count
        vb.customize ["modifyvm", :id, "--vram", "128"]
        vb.customize ["modifyvm", :id, "--pae", "on"]
      end

      # PROVISIONING
      # Basic setup to ensure password-less sudo and user access
      node.vm.provision "shell", inline: <<-SHELL
        echo "vagrant:vagrant" | sudo chpasswd
        # Ensure the disk is visible
        lsblk
      SHELL
    end
  end
end
